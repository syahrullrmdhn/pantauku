<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🐼"
        android:textSize="64sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pan Browser v1.0"
        android:textSize="20sp"
        android:textColor="#1565C0"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="Browser ringan dengan fitur aksesibilitas untuk membantu navigasi web."
        android:textSize="13sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Device Name Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nama Perangkat"
        android:textSize="12sp"
        android:textColor="#999999"
        android:layout_marginBottom="4dp"
        android:paddingLeft="4dp"
        android:paddingRight="4dp" />

    <EditText
        android:id="@+id/etDeviceName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Contoh: HP Syahrul"
        android:textSize="14sp"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="16dp"
        android:singleLine="true"
        android:maxLength="50" />

    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aktifkan Bantuan Aksesibilitas"
        android:layout_marginBottom="12dp"
        android:padding="16dp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1565C0" />

    <Button
        android:id="@+id/btnBattery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Optimalkan Daya Baterai"
        android:layout_marginBottom="12dp"
        android:padding="16dp"
        android:textColor="#1565C0"
        style="@style/Widget.AppCompat.Button.Borderless" />

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mulai Jelajah"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0D47A1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dengan melanjutkan, Anda menyetujui layanan aksesibilitas untuk membantu navigasi konten web."
        android:textSize="11sp"
        android:textColor="#999999"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp" />

</LinearLayout>
